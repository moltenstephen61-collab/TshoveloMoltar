<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>StartSession</servlet-name>
        <servlet-class>ac.za.tut.web.StartSession</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EndSession</servlet-name>
        <servlet-class>ac.za.tut.web.EndSession</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SetQuestions</servlet-name>
        <servlet-class>ac.za.tut.web.SetQuestions</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StartMultipleChoiceTest</servlet-name>
        <servlet-class>ac.za.tut.web.StartMultipleChoiceTest</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CalculateStudentMarks</servlet-name>
        <servlet-class>ac.za.tut.web.CalculateStudentMarks</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StartSession</servlet-name>
        <url-pattern>/StartSession.do</url-pattern>
    </servlet-mapping>
    <error-page>
        <exception-type>java.lang.IllegalArgumentException</exception-type>
        <location>/error_handling.jsp</location>
    </error-page>
    <servlet-mapping>
        <servlet-name>EndSession</servlet-name>
        <url-pattern>/EndSession.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SetQuestions</servlet-name>
        <url-pattern>/SetQuestions.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StartMultipleChoiceTest</servlet-name>
        <url-pattern>/StartMultipleChoiceTest.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CalculateStudentMarks</servlet-name>
        <url-pattern>/CalculateStudentMarks.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <context-param>
        <param-name>computer</param-name>
        <param-value>Siri</param-value>
    </context-param>
</web-app>
