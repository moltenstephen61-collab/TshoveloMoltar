<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>AddAnAcount</servlet-name>
        <servlet-class>ac.za.tut.web.AddAnAcount</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewAllAccountsWithDetails</servlet-name>
        <servlet-class>ac.za.tut.web.ViewAllAccountsWithDetails</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SearchAccountByAccountNumber</servlet-name>
        <servlet-class>ac.za.tut.web.SearchAccountByAccountNumber</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RemoveAnAccountByAccountNumber</servlet-name>
        <servlet-class>ac.za.tut.web.RemoveAnAccountByAccountNumber</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditAccountDetails</servlet-name>
        <servlet-class>ac.za.tut.web.EditAccountDetails</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DisplayTotalNumberOfAccounts</servlet-name>
        <servlet-class>ac.za.tut.web.DisplayTotalNumberOfAccounts</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddAnAcount</servlet-name>
        <url-pattern>/AddAnAcount.do</url-pattern>
    </servlet-mapping>
    <error-page>
        <exception-type>java.lang.IllegalArgumentException</exception-type>
        <location>/handled_error.jsp</location>
    </error-page>
    <servlet-mapping>
        <servlet-name>ViewAllAccountsWithDetails</servlet-name>
        <url-pattern>/ViewAllAccountsWithDetails.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SearchAccountByAccountNumber</servlet-name>
        <url-pattern>/SearchAccountByAccountNumber.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RemoveAnAccountByAccountNumber</servlet-name>
        <url-pattern>/RemoveAnAccountByAccountNumber.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditAccountDetails</servlet-name>
        <url-pattern>/EditAccountDetails.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DisplayTotalNumberOfAccounts</servlet-name>
        <url-pattern>/DisplayTotalNumberOfAccounts.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
