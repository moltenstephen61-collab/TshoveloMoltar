<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>LoginServelet</servlet-name>
        <servlet-class>ac.za.tut.web.LoginServelet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EndSession</servlet-name>
        <servlet-class>ac.za.tut.web.EndSession</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SetMultipleChoiceTest</servlet-name>
        <servlet-class>ac.za.tut.web.SetMultipleChoiceTest</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StartTest</servlet-name>
        <servlet-class>ac.za.tut.web.StartTest</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CalculateMarks</servlet-name>
        <servlet-class>ac.za.tut.web.CalculateMarks</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewAllStudentsWhoPassed</servlet-name>
        <servlet-class>ac.za.tut.web.ViewAllStudentsWhoPassed</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServelet</servlet-name>
        <url-pattern>/LoginServelet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EndSession</servlet-name>
        <url-pattern>/EndSession.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SetMultipleChoiceTest</servlet-name>
        <url-pattern>/SetMultipleChoiceTest.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StartTest</servlet-name>
        <url-pattern>/StartTest.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CalculateMarks</servlet-name>
        <url-pattern>/CalculateMarks.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ViewAllStudentsWhoPassed</servlet-name>
        <url-pattern>/ViewAllStudentsWhoPassed.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <security-constraint>
        <display-name>LecturerConstraint</display-name>
        <web-resource-collection>
            <web-resource-name>LecturerPrivateResources</web-resource-name>
            <description/>
            <url-pattern>/lecturer_menu.html</url-pattern> 
            <url-pattern>/view_students_passed.html</url-pattern>
            <url-pattern>/ViewAllStudentsWhoPassed.do</url-pattern>
            <url-pattern>/get_passed_students_outcome.jsp</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <description/>
            <role-name>Lecturer</role-name>
        </auth-constraint>
    </security-constraint>
    <security-constraint>
        <display-name>StudentConstraint</display-name>
        <web-resource-collection>
            <web-resource-name>StudentPrivateResources</web-resource-name>
            <description/>
            <url-pattern>/student_menu.html</url-pattern>
            <url-pattern>/take_test.jsp</url-pattern>
            <url-pattern>/Quiz_started.jsp</url-pattern>
            <url-pattern>/StartTest.do</url-pattern>
            <url-pattern>/CalculateMarks.do</url-pattern>
            <url-pattern>/Quiz_Results.jsp</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <description/>
            <role-name>Student</role-name>
        </auth-constraint>
    </security-constraint>
    <security-constraint>
        <display-name>PublicConstraint</display-name>
        <web-resource-collection>
            <web-resource-name>PublicResource</web-resource-name>
            <description/>
            <url-pattern>/LoginServelet.do</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <description/>
            <role-name>Lecturer</role-name>
            <role-name>Student</role-name>
        </auth-constraint>
    </security-constraint>
    <login-config>
        <auth-method>FORM</auth-method>
        <realm-name>file</realm-name>
        <form-login-config>
            <form-login-page>/login.jsp</form-login-page>
            <form-error-page>/Login_Error.jsp</form-error-page>
        </form-login-config>
    </login-config>
    <security-role>
        <description>This Is The Lecturer's Role.</description>
        <role-name>Lecturer</role-name>
    </security-role>
    <security-role>
        <description>This Is Student's Role.</description>
        <role-name>Student</role-name>
    </security-role>
</web-app>
