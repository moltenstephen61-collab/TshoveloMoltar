<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>AnalyzeShortMessages</servlet-name>
        <servlet-class>ac.za.tut.web.AnalyzeShortMessages</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewSummaryReports</servlet-name>
        <servlet-class>ac.za.tut.web.ViewSummaryReports</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EndSession</servlet-name>
        <servlet-class>ac.za.tut.web.EndSession</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewAnalysisOfLongestReport</servlet-name>
        <servlet-class>ac.za.tut.web.ViewAnalysisOfLongestReport</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnalyzeShortMessages</servlet-name>
        <url-pattern>/AnalyzeShortMessages.do</url-pattern>
    </servlet-mapping>
    <error-page>
        <exception-type>java.lang.IllegalArgumentException</exception-type>
        <location>/error-invalid-message.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error-404.jsp</location>
    </error-page>
    <servlet-mapping>
        <servlet-name>ViewSummaryReports</servlet-name>
        <url-pattern>/ViewSummaryReports.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EndSession</servlet-name>
        <url-pattern>/EndSession.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ViewAnalysisOfLongestReport</servlet-name>
        <url-pattern>/ViewAnalysisOfLongestReport.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
